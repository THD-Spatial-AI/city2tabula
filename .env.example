# This is a sample .env file for configuring the CityDB and Tabula datasets.
# Make sure to replace the placeholder values with your actual configuration.
# This file should be placed in the root directory of the project.

# Global Configuration
# Specify the country you want to train from the list of 'available countries' below
COUNTRY=germany

#########################
## Available countries ##
#########################
# 1.  austria
# 2.  belgium
# 3.  cyprus
# 4.  czechia
# 5.  denmark
# 6.  france
# 7.  germany
# 8.  greece
# 9.  hungary
# 10. ireland
# 11. italy
# 12. netherlands
# 13. norway
# 14. poland
# 15. serbia
# 16. slovenia
# 17. spain
# 18. sweden
# 19. united_kingdom

# Note: These countries are available based on the TABULA and EPISCOPE project data. Therefore running pipeline on other countries is not supported.

# Database connection settings
# Provide existing database name or create a new database for the project and provide its name here.
DB_NAME=<your_db_name_here>
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=<your_pg_password_here>

# 'enable' it for production
DB_SSL_MODE=disable

# CityDB Configuration

CITYDB_TOOL_PATH=<path/to/citydb-tool-1.X.X>

# Replace with the actual SRID and SRS name for your country.
CITYDB_SRID=25832
CITYDB_SRS_NAME=ETRS89 / UTM zone 32N


## SRID and SRS for supported countries (based on TABULA and EPISCOPE project data)

# Austria: 31256 (MGI / Austria GK East)
# Belgium: 31370 (Belgian Lambert 72)
# Cyprus: 3879 (GRS 1980 / Cyprus TM)
# Czechia: 5514 (S-JTSK / Krovak East North)
# Denmark: 25832 (ETRS89 / UTM zone 32N)
# France: 2154 (RGF93 / Lambert-93)
# Germany: 25832 (ETRS89 / UTM zone 32N)
# Greece: 2100 (GGRS87 / Greek Grid)
# Hungary: 23700 (EOV)
# Ireland: 29902 (Irish National Grid)
# Italy: 3003 (Monte Mario / Italy zone 1)
# Netherlands: 28992 (Amersfoort / RD New)
# Norway: 25833 (ETRS89 / UTM zone 33N)
# Serbia: 3114 (Serbian 1970 / Serbian Grid)
# Slovenia: 3794 (Slovenia 1996 / Slovene National Grid)
# Switzerland: 2056 (CH1903+ / LV95)
# Poland: 2180 (ETRS89 / Poland CS2000 zone 5)
# Spain: 25830 (ETRS89 / UTM zone 30N)
# Sweden: 3006 (SWEREF99 TM)
# United Kingdom: 27700 (OSGB 1936 / British National Grid)

# Parallel Processing Configuration
THREAD_COUNT=4        # Number of threads for parallel processing (optional)


# Logging Configuration
LOG_LEVEL=INFO
# Set the logging level (DEBUG, INFO, WARN, ERROR)
# For development: DEBUG - shows all debug information
# For production: INFO - shows essential information only
# For monitoring: WARN - shows only warnings and errors

# Testing / Development Limits
# IMPORT_LIMIT:    caps features pulled from GML files by the citydb-tool during `create-db`.
#                  Useful for creating a small test DB without importing the full dataset.
#                  Does not affect subsequent feature extraction runs on an already-imported DB.
IMPORT_LIMIT=0         # e.g. 1000  (0 or empty = import everything)

# BUILDING_LIMIT:  caps how many buildings the City2TABULA extraction pipeline processes.
#                  Set this to debug or benchmark against a subset of an already-imported DB.
#                  Independent of IMPORT_LIMIT — the DB can hold 50k buildings while you only
#                  extract/process 100 of them.
BUILDING_LIMIT=0       # e.g. 100   (0 or empty = process all buildings in the 3DCityDB schema)

# VALIDATION_LIMIT: caps matched validation pairs per category (buildings, roof surfaces,
#                   wall surfaces, floor surfaces). The load functions JOIN directly with
#                   City2TABULA tables and apply LIMIT at the DB level, so validation
#                   continues until N matches are found or the full dataset is exhausted.
#                   Sampling is random (ORDER BY RANDOM() in SQL).
#                   Set to 10000 for consistent cross-dataset comparisons in the paper.
VALIDATION_LIMIT=0     # e.g. 10000  (0 or empty = validate all available matches)